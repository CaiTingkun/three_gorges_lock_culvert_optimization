<script>
const defaults = {
  L:280, B:34, Hk:5, dH:45.2,
  tmax:13, Amin:68.91, Amax:300,
  qcoef:1.2598, Qv:368.64, vbase:4, vmax:6,
  a:0.08, Cfix:47.45, K0:679.48,
  AplotMin:40, AplotMax:330
};
const ids = Object.keys(defaults);
let latestData = [];

function getVal(id){
  const x = parseFloat(document.getElementById(id).value);
  return Number.isFinite(x) ? x : defaults[id];
}
function setVal(id,x){ document.getElementById(id).value = x; }
function fmt(x,d=2){
  if(!Number.isFinite(x)) return "—";
  return x.toLocaleString("zh-CN",{maximumFractionDigits:d,minimumFractionDigits:d});
}
function fmt0(x){
  if(!Number.isFinite(x)) return "—";
  return x.toLocaleString("zh-CN",{maximumFractionDigits:0});
}
function params(){
  const p = {};
  ids.forEach(id => p[id] = getVal(id));
  p.L = Math.max(p.L,0.001);
  p.B = Math.max(p.B,0.001);
  p.Hk = Math.max(p.Hk,0.001);
  p.tmax = Math.max(p.tmax,0.001);
  p.Amin = Math.max(p.Amin,0.001);
  p.Amax = Math.max(p.Amax,p.Amin+0.001);
  p.AplotMin = Math.max(p.AplotMin,0.001);
  p.AplotMax = Math.max(p.AplotMax,p.AplotMin+0.001);
  p.a = Math.max(p.a,0.000001);
  p.K0 = Math.max(p.K0,0.000001);
  p.vmax = Math.max(p.vmax,0.000001);
  return p;
}
function derived(p){
  const V = p.L*p.B*p.Hk;
  const Vref = defaults.L * defaults.B * defaults.Hk;
  const volumeScale = V / Vref;
  // 报告默认 Ct=Amin*tmax；修改闸室尺寸后，按体积比例联动修正。
  const Ct = p.Amin * p.tmax * volumeScale;
  // 运营延误损失与输水时间同向变化，因此 K0 按同一体积比例联动。
  const K0eff = p.K0 * volumeScale;
  const Astar = Math.sqrt(K0eff / p.a);
  const AminEff = Ct / p.tmax;
  return {V,Vref,volumeScale,Ct,K0eff,Astar,AminEff};
}
function model(A,p,d){
  const t = d.Ct/A;
  const Q = p.qcoef*A;
  const v = p.Qv/A;
  const Ccon = p.a*A + p.Cfix;
  const Cop = d.K0eff/A;
  const TC = Ccon + Cop;
  const okT = t <= p.tmax;
  const okA = A >= d.AminEff && A <= p.Amax;
  const okV = v <= p.vmax;
  return {A,Atotal:2*A,t,Q,v,Ccon,Cop,TC,okT,okA,okV};
}
function clamp(x,lo,hi){ return Math.min(Math.max(x,lo),hi); }
function recommend(p,d){
  // 下限同时考虑报告水力下限随体积变化后的 A水力，以及流速约束下限。
  let lo = d.AminEff;
  const hi = p.Amax;
  const Av = p.Qv / p.vmax;
  lo = Math.max(lo, Av);
  const A = clamp(d.Astar, lo, hi);
  const feasible = lo <= hi;
  return {A,lo,hi,feasible};
}
function sample(p,d){
  const arr=[];
  const n=360;
  for(let i=0;i<n;i++){
    const A = p.AplotMin + (p.AplotMax-p.AplotMin)*i/(n-1);
    arr.push(model(A,p,d));
  }
  return arr;
}
function status(m){
  if(m.okT && m.okA && m.okV) return '<span class="status ok">可行</span>';
  const f=[];
  if(!m.okT) f.push("超时");
  if(!m.okA) f.push("越界");
  if(!m.okV) f.push("流速超限");
  return '<span class="status bad">'+f.join("/")+'</span>';
}
function updateOutputs(p,d,rec,m){
  document.getElementById("AstarOut").textContent = fmt(d.Astar,2) + " m²";
  document.getElementById("ArecOut").textContent = fmt(rec.A,2) + " m²";
  document.getElementById("tOut").textContent = fmt(m.t,2) + " min";
  document.getElementById("TCOut").textContent = fmt(m.TC,2) + " 亿元";
  document.getElementById("Vout").textContent = fmt0(d.V) + " m³";
  document.getElementById("CtOut").textContent = fmt(d.Ct,2) + " min·m²";
  document.getElementById("scaleOut").textContent = fmt(d.volumeScale,3);
  document.getElementById("Qout").textContent = fmt(m.Q,2) + " m³/s";
  document.getElementById("vOut").textContent = fmt(m.v,2) + " m/s";
  document.getElementById("CconOut").textContent = fmt(m.Ccon,2) + " 亿元";
  document.getElementById("CopOut").textContent = fmt(m.Cop,2) + " 亿元";
  document.getElementById("AtotalOut").textContent = fmt(m.Atotal,2) + " m²";
  document.getElementById("AeffOut").textContent = fmt(d.AminEff,2) + " m²";
  document.getElementById("statusOut").innerHTML = status(m);

  let s = "";
  if(!rec.feasible){
    s = "约束区间不可行，请提高 Amax 或放宽流速约束。";
  }else if(Math.abs(rec.A-d.Astar)<1e-4){
    s = "理论最优断面位于可行区间，可直接作为推荐断面。";
  }else if(rec.A > d.Astar){
    s = "理论最优断面偏小，已按水力/安全下限修正。";
  }else{
    s = "理论最优断面超过空间上限，已修正至 Amax。";
  }
  document.getElementById("recSub").textContent = s;
}
function table(p,d,rec){
  const cases = [
    ["水力控制下限 A<sub>水力</sub>", d.AminEff],
    ["理论最优断面 A*", d.Astar]
  ];

  // 只有当推荐实施断面与理论最优断面不相同时，才单独显示推荐行
  if(Math.abs(rec.A - d.Astar) > 1e-4){
    cases.push(["推荐实施断面", rec.A]);
  }

  cases.push(["偏大断面 A<sub>max</sub>", p.Amax]);

  const rows=[];
  const seen=new Set();
  for(const [name,A] of cases){
    const key=A.toFixed(4);
    if(seen.has(key)) continue;
    seen.add(key);
    const m=model(A,p,d);
    rows.push(`<tr>
      <td>${name}</td>
      <td>${fmt(A,2)}</td>
      <td>${fmt(m.t,2)}</td>
      <td>${fmt(m.Q,2)}</td>
      <td>${fmt(m.v,2)}</td>
      <td>${fmt(m.Ccon,2)}</td>
      <td>${fmt(m.Cop,2)}</td>
      <td>${fmt(m.TC,2)}</td>
      <td>${status(m)}</td>
    </tr>`);
  }
  document.getElementById("tableRows").innerHTML=rows.join("");
}
function drawChart(canvas,data,series,yLabel,markers={},opts={}){
  const ctx=canvas.getContext("2d");
  const rect=canvas.getBoundingClientRect();
  const ratio=window.devicePixelRatio||1;
  canvas.width=rect.width*ratio; canvas.height=rect.height*ratio;
  ctx.setTransform(ratio,0,0,ratio,0,0);
  const w=rect.width,h=rect.height;
  ctx.clearRect(0,0,w,h);

  // 顶部为最佳断面数据标记预留空间
  const pad={l:66,r:34,t:56,b:56};
  const pw=w-pad.l-pad.r, ph=h-pad.t-pad.b;
  const xs=data.map(d=>d.A);
  const ys=[];
  series.forEach(s=>data.forEach(d=>ys.push(d[s.key])));
  if(opts.yLine!==undefined) ys.push(opts.yLine);
  if(opts.yLine2!==undefined) ys.push(opts.yLine2);

  const xmin=Math.min(...xs),xmax=Math.max(...xs);
  let ymin=Math.min(...ys),ymax=Math.max(...ys);
  if(Math.abs(ymax-ymin)<1e-9){ymax+=1;ymin-=1}
  const span=ymax-ymin; ymin-=span*.08; ymax+=span*.10;
  const X=x=>pad.l+(x-xmin)/(xmax-xmin)*pw;
  const Y=y=>pad.t+ph-(y-ymin)/(ymax-ymin)*ph;

  // 可行区间浅色背景
  if(opts.Amin !== undefined && opts.Amax !== undefined){
    const x1=Math.max(pad.l, X(opts.Amin));
    const x2=Math.min(w-pad.r, X(opts.Amax));
    if(x2>x1){
      ctx.fillStyle="rgba(245,158,11,.10)";
      ctx.fillRect(x1,pad.t,x2-x1,ph);
    }
  }

  // 坐标轴与网格
  const tickCount=4;
  ctx.font="12px -apple-system,BlinkMacSystemFont,Segoe UI,Microsoft YaHei,Arial";
  ctx.strokeStyle="#e5e7eb"; ctx.lineWidth=1; ctx.fillStyle="#6b7280";
  ctx.textAlign="right"; ctx.textBaseline="middle";
  for(let i=0;i<=tickCount;i++){
    const y=pad.t+ph*i/tickCount;
    ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(w-pad.r,y); ctx.stroke();
    const val=ymax-(ymax-ymin)*i/tickCount;
    ctx.fillText(fmt(val, opts.yDecimals ?? 0),pad.l-9,y);
  }

  ctx.textAlign="center"; ctx.textBaseline="top";
  for(let i=0;i<=tickCount;i++){
    const x=pad.l+pw*i/tickCount;
    ctx.beginPath(); ctx.moveTo(x,pad.t); ctx.lineTo(x,pad.t+ph); ctx.stroke();
    const val=xmin+(xmax-xmin)*i/tickCount;
    ctx.fillText(fmt0(val),x,pad.t+ph+14);
  }

  ctx.strokeStyle="#94a3b8"; ctx.lineWidth=1.3;
  ctx.beginPath(); ctx.moveTo(pad.l,pad.t); ctx.lineTo(pad.l,pad.t+ph); ctx.lineTo(w-pad.r,pad.t+ph); ctx.stroke();

  ctx.save(); ctx.translate(16,pad.t+ph/2); ctx.rotate(-Math.PI/2);
  ctx.fillStyle="#475569"; ctx.textAlign="center"; ctx.textBaseline="middle"; ctx.fillText(yLabel,0,0);
  ctx.restore();
  ctx.fillStyle="#475569"; ctx.textAlign="center"; ctx.textBaseline="top";
  ctx.fillText("单条输水廊道断面面积 A（m²）",pad.l+pw/2,h-27);

  // 横线：所有数据标记与横线保持完全一致的垂直距离
  const hLabelOffset = 14;  // 标签基线距离横线的固定距离
  function hline(yval,label,color){
    const y=Y(yval);
    ctx.strokeStyle=color; ctx.setLineDash([7,6]); ctx.lineWidth=1.3;
    ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(w-pad.r,y); ctx.stroke();
    ctx.setLineDash([]);
    const ty=Math.max(pad.t+12, Math.min(y - hLabelOffset, pad.t+ph-10));
    ctx.fillStyle=color;
    ctx.font="12px -apple-system,BlinkMacSystemFont,Segoe UI,Microsoft YaHei,Arial";
    ctx.textAlign="center";
    ctx.textBaseline="bottom";
    ctx.fillText(label,pad.l+pw/2,ty);
  }
  if(opts.yLine!==undefined) hline(opts.yLine,opts.yLabel||fmt(opts.yLine,1),opts.yColor||"#ef4444");
  if(opts.yLine2!==undefined) hline(opts.yLine2,opts.yLabel2||fmt(opts.yLine2,1),opts.yColor2||"#f59e0b");

  // 曲线
  for(const s of series){
    ctx.strokeStyle=s.color; ctx.lineWidth=s.width||2.3; ctx.setLineDash(s.dash||[]);
    ctx.beginPath();
    data.forEach((d,i)=>{
      const x=X(d.A),y=Y(d[s.key]);
      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    });
    ctx.stroke(); ctx.setLineDash([]);
  }

  // 竖线：仅保留最佳断面 A* 的数据标签；标签带单位且不加外框
  const verticals = [];
  if(markers.Amin) verticals.push({x:markers.Amin,color:"#0f766e",showLabel:false});
  if(markers.Astar) verticals.push({x:markers.Astar,color:"#dc2626",showLabel:true,label:fmt(markers.Astar,1) + " m²"});
  if(markers.Amax) verticals.push({x:markers.Amax,color:"#7c3aed",showLabel:false});

  verticals.forEach(mk=>{
    const x=X(mk.x);
    if(x<pad.l || x>w-pad.r) return;
    ctx.strokeStyle=mk.color; ctx.setLineDash([4,5]); ctx.lineWidth=1.3;
    ctx.beginPath(); ctx.moveTo(x,pad.t); ctx.lineTo(x,pad.t+ph); ctx.stroke();
    ctx.setLineDash([]);

    if(mk.showLabel){
      ctx.fillStyle=mk.color;
      ctx.font="12px -apple-system,BlinkMacSystemFont,Segoe UI,Microsoft YaHei,Arial";
      ctx.textAlign="center";
      ctx.textBaseline="bottom";
      ctx.fillText(mk.label, x, pad.t-8);
    }
  });

  // 关键交点：默认显示在指定曲线上的对应点。
  if(markers.point){
    const key=opts.pointKey||series[0].key;
    const pointXValue = (opts.pointX === "Astar" && markers.Astar) ? markers.Astar : markers.point.A;
    const pointYValue = (opts.pointYValue !== undefined) ? opts.pointYValue : markers.point[key];
    const x=X(pointXValue), y=Y(pointYValue);

    ctx.fillStyle=opts.pointColor || "#111827";
    ctx.beginPath();
    ctx.arc(x,y,5.5,0,Math.PI*2);
    ctx.fill();

    if(opts.pointStroke){
      ctx.strokeStyle=opts.pointStroke;
      ctx.lineWidth=1.4;
      ctx.stroke();
    }
  }
}

function drawBar(canvas,bars){
  const ctx=canvas.getContext("2d");
  const rect=canvas.getBoundingClientRect();
  const ratio=window.devicePixelRatio||1;
  canvas.width=rect.width*ratio; canvas.height=rect.height*ratio;
  ctx.setTransform(ratio,0,0,ratio,0,0);
  const w=rect.width,h=rect.height;
  ctx.clearRect(0,0,w,h);

  const pad={l:60,r:30,t:52,b:86};
  const pw=w-pad.l-pad.r,ph=h-pad.t-pad.b;
  const maxY=Math.max(...bars.map(b=>b.Ccon+b.Cop))*1.18;
  const Y=y=>pad.t+ph-y/maxY*ph;

  function roundRect(x,y,width,height,r){
    const rr=Math.min(r,width/2,height/2);
    ctx.beginPath();
    ctx.moveTo(x+rr,y);
    ctx.arcTo(x+width,y,x+width,y+height,rr);
    ctx.arcTo(x+width,y+height,x,y+height,rr);
    ctx.arcTo(x,y+height,x,y,rr);
    ctx.arcTo(x,y,x+width,y,rr);
    ctx.closePath();
  }

  function labelBox(text,x,y){
    ctx.font="12px -apple-system,BlinkMacSystemFont,Segoe UI,Microsoft YaHei,Arial";
    const tw=ctx.measureText(text).width;
    const bw=tw+12,bh=21;
    const bx=Math.max(6,Math.min(x-bw/2,w-bw-6));
    const by=Math.max(6,Math.min(y,h-bh-6));
    ctx.fillStyle="rgba(255,255,255,.95)";
    roundRect(bx,by,bw,bh,8);
    ctx.fill();
    ctx.strokeStyle="#cbd5e1";
    ctx.lineWidth=1;
    ctx.stroke();
    ctx.fillStyle="#111827";
    ctx.textAlign="left";
    ctx.textBaseline="middle";
    ctx.fillText(text,bx+6,by+bh/2);
  }

  ctx.font="12px -apple-system,BlinkMacSystemFont,Segoe UI,Microsoft YaHei,Arial";
  ctx.strokeStyle="#e5e7eb"; ctx.fillStyle="#6b7280"; ctx.textAlign="right"; ctx.textBaseline="middle";
  const tickCount=4;
  for(let i=0;i<=tickCount;i++){
    const y=pad.t+ph*i/tickCount;
    ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(w-pad.r,y); ctx.stroke();
    ctx.fillText(fmt(maxY*(1-i/tickCount),1),pad.l-8,y);
  }
  ctx.strokeStyle="#94a3b8"; ctx.beginPath(); ctx.moveTo(pad.l,pad.t); ctx.lineTo(pad.l,pad.t+ph); ctx.lineTo(w-pad.r,pad.t+ph); ctx.stroke();
  ctx.save(); ctx.translate(16,pad.t+ph/2); ctx.rotate(-Math.PI/2); ctx.fillStyle="#475569"; ctx.textAlign="center"; ctx.fillText("成本（亿元）",0,0); ctx.restore();

  const slot=pw/bars.length;
  const bw=Math.min(58,slot*.45);
  bars.forEach((b,i)=>{
    const center=pad.l+slot*(i+.5);
    const x=center-bw/2;
    const yCon=Y(b.Ccon);
    const yTotal=Y(b.Ccon+b.Cop);

    ctx.fillStyle="#0f766e"; ctx.fillRect(x,yCon,bw,pad.t+ph-yCon);
    ctx.fillStyle="#b45309"; ctx.fillRect(x,yTotal,bw,yCon-yTotal);

    // 顶部数值标签交错显示，避免遮挡。
    labelBox(fmt(b.Ccon+b.Cop,2)+" 亿",center,yTotal-29-(i%2)*14);

    ctx.fillStyle="#475569"; ctx.textAlign="center"; ctx.textBaseline="top";
    ctx.fillText(b.name,center,pad.t+ph+14);
    ctx.fillText("A="+fmt(b.A,1),center,pad.t+ph+34);
  });
}

function recalc(){
  const p=params();
  const d=derived(p);
  const rec=recommend(p,d);
  const m=model(rec.A,p,d);
  const data=sample(p,d);
  latestData=data;
  updateOutputs(p,d,rec,m);
  table(p,d,rec);
  const markers={Amin:d.AminEff,Astar:d.Astar,Amax:p.Amax,point:m};

  drawChart(document.getElementById("costCanvas"),data,[
    {key:"TC",color:"#2563eb",width:2.8},
    {key:"Ccon",color:"#0f766e",width:2.1},
    {key:"Cop",color:"#b45309",width:2.1}
  ],"成本现值（亿元）",markers,{
    Amin:d.AminEff,
    Amax:p.Amax,
    pointKey:"TC",
    pointX:"Astar",
    pointYValue:model(d.Astar,p,d).TC,
    pointColor:"#dc2626",
    pointStroke:"#ffffff",
    yDecimals:1
  });

  drawChart(document.getElementById("timeCanvas"),data,[
    {key:"t",color:"#7c3aed",width:2.8}
  ],"充泄水时长（min）",markers,{
    Amin:d.AminEff,
    Amax:p.Amax,
    pointKey:"t",
    pointX:"Astar",
    pointYValue:model(d.Astar,p,d).t,
    pointColor:"#dc2626",
    pointStroke:"#ffffff",
    yLine:p.tmax,
    yLabel:"tmax="+fmt(p.tmax,1)+" min",
    yDecimals:1
  });

  drawChart(document.getElementById("flowCanvas"),data,[
    {key:"Q",color:"#be123c",width:2.8}
  ],"输水流量 Q（m³/s）",markers,{
    Amin:d.AminEff,
    Amax:p.Amax,
    pointKey:"Q",
    pointX:"Astar",
    pointYValue:model(d.Astar,p,d).Q,
    pointColor:"#dc2626",
    pointStroke:"#ffffff",
    yDecimals:0
  });

  drawChart(document.getElementById("velocityCanvas"),data,[
    {key:"v",color:"#111827",width:2.8}
  ],"廊道平均流速 v（m/s）",markers,{
    Amin:d.AminEff,
    Amax:p.Amax,
    pointKey:"v",
    pointX:"Astar",
    pointYValue:model(d.Astar,p,d).v,
    pointColor:"#dc2626",
    pointStroke:"#ffffff",
    yLine:p.vmax,
    yLabel:"vmax="+fmt(p.vmax,1)+" m/s",
    yColor:"#ef4444",
    yLine2:p.vbase,
    yLabel2:"vbase="+fmt(p.vbase,1)+" m/s",
    yColor2:"#f59e0b",
    yDecimals:1
  });

  const barCases=[
    {name:"水力下限",...model(d.AminEff,p,d)},
    {name:"最优断面",...model(d.Astar,p,d)},
    {name:"偏大断面",...model(p.Amax,p,d)}
  ];
  drawBar(document.getElementById("barCanvas"),barCases);
}
function reset(){
  ids.forEach(id=>setVal(id,defaults[id]));
  recalcAnimated();
}
function exportCSV(){
  const p=params(), d=derived(p);
  if(!latestData.length) latestData=sample(p,d);
  const header=["A_m2","A_total_m2","t_min","Q_m3_s","v_m_s","Ccon_billion_CNY","Cop_billion_CNY","TC_billion_CNY","ok_time","ok_area","ok_velocity","volume_scale","K0_effective"];
  const rows=latestData.map(m=>[m.A,m.Atotal,m.t,m.Q,m.v,m.Ccon,m.Cop,m.TC,m.okT,m.okA,m.okV,d.volumeScale,d.K0eff].join(","));
  const csv="\uFEFF"+header.join(",")+"\n"+rows.join("\n");
  const blob=new Blob([csv],{type:"text/csv;charset=utf-8"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a");
  a.href=url;
  a.download="三峡船闸输水廊道断面优化报告标定数据.csv";
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

let calcTimer = null;
let stepTimer = null;
let hasPendingChanges = false;

function allChartCanvases(){
  return ["costCanvas","timeCanvas","flowCanvas","velocityCanvas","barCanvas"]
    .map(id=>document.getElementById(id))
    .filter(Boolean);
}

function markChartsWaiting(){
  allChartCanvases().forEach(c=>c.classList.add("waiting-update"));
}

function clearChartsWaiting(){
  allChartCanvases().forEach(c=>c.classList.remove("waiting-update"));
}

function flashChartsUpdated(){
  const charts = allChartCanvases();
  charts.forEach(c=>{
    c.classList.remove("chart-updated");
    void c.offsetWidth;
    c.classList.add("chart-updated");
  });
  const toast = document.getElementById("updateToast");
  if(toast){
    toast.classList.remove("show");
    void toast.offsetWidth;
    toast.classList.add("show");
  }
}

function setCalcStep(index, progress, text){
  for(let i=1;i<=4;i++){
    const el = document.getElementById("step"+i);
    if(el) el.classList.toggle("active", i === index);
  }
  const bar = document.getElementById("calcProgress");
  if(bar) bar.style.width = progress + "%";
  const desc = document.getElementById("calcDesc");
  if(desc && text) desc.textContent = text;
}

function setInlineDirty(){
  const inline = document.getElementById("calcInline");
  if(!inline) return;
  inline.classList.add("show","dirty");
  inline.innerHTML = "参数已修改，按 Enter 计算";
}

function setInlineCalculating(){
  const inline = document.getElementById("calcInline");
  if(!inline) return;
  inline.classList.remove("dirty");
  inline.classList.add("show");
  inline.innerHTML = '<span class="mini-spinner"></span>正在计算';
}

function clearInlineStatus(){
  const inline = document.getElementById("calcInline");
  if(!inline) return;
  inline.classList.remove("show","dirty");
  inline.innerHTML = '<span class="mini-spinner"></span>正在计算';
}

function markDirty(){
  hasPendingChanges = true;
  clearTimeout(calcTimer);
  clearInterval(stepTimer);
  setInlineDirty();
  markChartsWaiting();
}

function showCalcAnimation(){
  const overlay = document.getElementById("calcOverlay");
  if(overlay) overlay.classList.add("show");
  setInlineCalculating();

  const steps = [
    [1,18,"已收到计算指令，正在读取输入并更新水力边界。"],
    [2,46,"正在计算理论最优断面、输水时长、流量与流速。"],
    [3,72,"正在进行时间约束、空间约束与流速约束校核。"],
    [4,92,"正在刷新成本曲线、A-t 曲线、A-Q 曲线、A-v 曲线和方案表。"]
  ];

  clearInterval(stepTimer);
  let idx = 0;
  setCalcStep(steps[0][0], steps[0][1], steps[0][2]);
  stepTimer = setInterval(()=>{
    idx = Math.min(idx + 1, steps.length - 1);
    setCalcStep(steps[idx][0], steps[idx][1], steps[idx][2]);
    if(idx === steps.length - 1) clearInterval(stepTimer);
  }, 130);
}

function hideCalcAnimation(){
  clearInterval(stepTimer);
  setCalcStep(4,100,"计算完成，图表已更新。");
  hasPendingChanges = false;
  setTimeout(()=>{
    const overlay = document.getElementById("calcOverlay");
    if(overlay) overlay.classList.remove("show");
    clearInlineStatus();
  }, 160);
}

function recalcAnimated(){
  showCalcAnimation();
  clearTimeout(calcTimer);
  calcTimer = setTimeout(()=>{
    recalc();
    clearChartsWaiting();
    flashChartsUpdated();
    hideCalcAnimation();
  }, 520);
}

function handleEnterToRecalc(event){
  if(event.key === "Enter"){
    event.preventDefault();
    recalcAnimated();
  }
}


ids.forEach(id=>{
  const el = document.getElementById(id);
  el.addEventListener("input",markDirty);
  el.addEventListener("keydown",handleEnterToRecalc);
});
document.addEventListener("keydown",event=>{
  if(event.key === "Enter" && hasPendingChanges){
    const tag = (event.target && event.target.tagName || "").toLowerCase();
    if(tag !== "button"){
      event.preventDefault();
      recalcAnimated();
    }
  }
});
document.getElementById("calcBtn").addEventListener("click",recalcAnimated);
document.getElementById("resetBtn").addEventListener("click",reset);
document.getElementById("csvBtn").addEventListener("click",exportCSV);
window.addEventListener("resize",recalc);
recalc();
</script>
<div class="update-toast" id="updateToast">图表已更新</div>
</body>
